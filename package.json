{
  "name": "github-trend-daily",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @github-trend-daily/web dev",
    "build": "pnpm --filter @github-trend-daily/web build",
    "preview": "pnpm --filter @github-trend-daily/web preview",
    "fetch": "pnpm --filter @github-trend-daily/collector start",
    "fetch:trending": "pnpm --filter @github-trend-daily/collector start:trending",
    "fetch:enrich": "pnpm --filter @github-trend-daily/collector start:enrich"
  },
  "devDependencies": {
    "typescript": "^5.6.2"
  },
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  }
}
