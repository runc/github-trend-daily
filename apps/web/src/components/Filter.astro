---
interface Props {
  languages: string[];
  sinces: string[];
  years: string[];
  current: { language: string; since: string; year: string };
  action: string;
}
const { languages, sinces, years, current, action } = Astro.props;
---

<form method="GET" action={action} class="flex flex-wrap items-center gap-3 mb-6">
  <label class="text-sm text-slate-600 dark:text-slate-300">Language</label>
  <select name="language" class="px-2 py-1 rounded border border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-800 text-sm">
    <option value="" selected={current.language === ''}>All</option>
    {languages.map(l => <option value={l} selected={current.language === l}>{l}</option>)}
  </select>

  <label class="text-sm text-slate-600 dark:text-slate-300 ml-3">Since</label>
  <select name="since" class="px-2 py-1 rounded border border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-800 text-sm">
    {sinces.map(s => <option value={s} selected={current.since === s}>{s}</option>)}
  </select>

  <label class="text-sm text-slate-600 dark:text-slate-300 ml-3">Year</label>
  <select name="year" class="px-2 py-1 rounded border border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-800 text-sm">
    <option value="" selected={current.year === ''}>All</option>
    {years.map(y => <option value={y} selected={current.year === y}>{y}</option>)}
  </select>

  <button type="submit" class="px-3 py-1 rounded bg-indigo-600 text-white text-sm hover:bg-indigo-700">Apply</button>
</form>
