---
interface Props {
  title?: string;
  description?: string;
  active?: 'trending' | 'free-ai';
}
const {
  title = 'GitHub Trending Daily RAG',
  description = '一个基于 GitHub Trending 的 AI 知识库 — 每日抓取 trending,通过 DeepWiki MCP 与 LLM 生成结构化仓库摘要、标签与分类。',
  active = 'trending',
} = Astro.props;
import '~/styles/global.css';
const base = import.meta.env.BASE_URL.replace(/\/$/, '') + '/';
---

<!doctype html>
<html lang="en" class="h-full">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" href={`${base}favicon.svg`} type="image/svg+xml" />
    <title>{title}</title>
  </head>
  <body data-base={base} class="h-full bg-slate-50 dark:bg-slate-900 text-slate-900 dark:text-slate-100">
    <header class="border-b border-slate-200 dark:border-slate-700">
      <div class="max-w-6xl mx-auto px-4 py-4 flex items-center justify-between gap-4">
        <div class="flex items-baseline gap-3 flex-wrap">
          <a href={base} class="font-bold text-lg">⭐ GitHub Trending Daily RAG</a>
          <span class="hidden sm:inline text-xs text-slate-400 dark:text-slate-500">一个基于 GitHub Trending 的 AI 知识库</span>
        </div>
        <div class="flex items-center gap-4">
          <nav class="flex items-center gap-1 text-sm">
            <a
              href={base}
              class={`px-3 py-1.5 rounded-md transition-colors ${active === 'trending' ? 'bg-indigo-50 dark:bg-indigo-900/30 text-indigo-700 dark:text-indigo-300 font-medium' : 'text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-slate-100 hover:bg-slate-100 dark:hover:bg-slate-800'}`}
            >Trending</a>
            <a
              href={`${base}free-ai`}
              class={`px-3 py-1.5 rounded-md transition-colors ${active === 'free-ai' ? 'bg-indigo-50 dark:bg-indigo-900/30 text-indigo-700 dark:text-indigo-300 font-medium' : 'text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-slate-100 hover:bg-slate-100 dark:hover:bg-slate-800'}`}
            >免费 AI 资源</a>
          </nav>
          <button
            id="theme-toggle"
            class="text-sm px-2 py-1 rounded border border-slate-300 dark:border-slate-600"
            aria-label="Toggle theme"
          >🌙</button>
        </div>
      </div>
    </header>

    <main class="max-w-6xl mx-auto px-4 py-6">
      <slot />
    </main>

    <footer class="max-w-6xl mx-auto px-4 py-8 text-xs text-slate-500 dark:text-slate-400 text-center">
      <p>Static site · Updated via GitHub Actions · Data © GitHub Trending</p>
    </footer>

    <script is:inline>
      const stored = localStorage.getItem('theme');
      if (stored === 'dark' || (!stored && matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark');
      }
      document.getElementById('theme-toggle')?.addEventListener('click', () => {
        document.documentElement.classList.toggle('dark');
        localStorage.setItem('theme', document.documentElement.classList.contains('dark') ? 'dark' : 'light');
      });
    </script>
  </body>
</html>
