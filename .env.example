# ---- Trending fetch scope ----
TREND_SINCE=daily,weekly,monthly
TREND_LANGUAGES=TypeScript,JavaScript,Python,Go,Rust,Java
TREND_SPOKEN_LANGUAGES=

# ---- LLM enrichment (OpenAI-compatible; default: DeepSeek) ----
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_API_KEY=sk-your-deepseek-key
OPENAI_MODEL=deepseek-chat
SUMMARY_LANG=中文

# ---- DeepWiki MCP ----
DEEPWIKI_MCP_URL=https://mcp.deepwiki.com/mcp

# ---- Tuning ----
ENRICH_CONCURRENCY=4
ENRICH_LIMIT_PER_SNAPSHOT=25
